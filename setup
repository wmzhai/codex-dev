#!/usr/bin/env bash
set -euo pipefail

PROJECT_NAME="codev"
REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)"
SKILLS_DIR="${HOME}/.codex/skills"
MANAGED_SKILLS=(issue2task plantask checktask simplify ships)

die() {
  echo "codev setup failed: $*" >&2
  exit 1
}

ensure_symlink_or_absent() {
  local path="$1"

  if [ -e "$path" ] && [ ! -L "$path" ]; then
    die "${path} already exists and is not a symlink"
  fi
}

mkdir -p "$SKILLS_DIR"

ensure_symlink_or_absent "${SKILLS_DIR}/${PROJECT_NAME}"

for skill_name in "${MANAGED_SKILLS[@]}"; do
  ensure_symlink_or_absent "${SKILLS_DIR}/${skill_name}"
done

ln -snf "$REPO_ROOT" "${SKILLS_DIR}/${PROJECT_NAME}"

for skill_name in "${MANAGED_SKILLS[@]}"; do
  ln -snf "${PROJECT_NAME}/${skill_name}" "${SKILLS_DIR}/${skill_name}"
done

echo "codev ready."
echo "  repo: ${REPO_ROOT}"
echo "  skills: ${SKILLS_DIR}"
echo "  linked: ${MANAGED_SKILLS[*]}"

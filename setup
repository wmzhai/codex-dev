#!/usr/bin/env bash
set -euo pipefail

PROJECT_NAME="codev"
REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)"
HOST=""
HOST_EXPLICIT=0
TARGET_HOSTS=()
MANAGED_SKILLS=(codev-memorize codev-issue2task codev-taskdev codev-quickship codev-simplify codev-checkpoint codev-syncpatch)
REMOVED_MANAGED_SKILLS=(codev-gstack2task codev-checktask codev-autodev codev-automerge)
LEGACY_CODEV_SKILLS=(plantask memorize issue2task gstack2task taskdev autodev automerge checktask simplify checkpoint ships)

die() {
  echo "codev setup failed: $*" >&2
  exit 1
}

parse_args() {
  while [ $# -gt 0 ]; do
    case "$1" in
      --host)
        [ $# -ge 2 ] || die "missing value for --host (expected codex)"
        HOST="$2"
        HOST_EXPLICIT=1
        shift 2
        ;;
      --host=*)
        HOST="${1#--host=}"
        HOST_EXPLICIT=1
        shift
        ;;
      *)
        die "unknown argument: $1"
        ;;
    esac
  done

  if [ "$HOST_EXPLICIT" -eq 1 ]; then
    case "$HOST" in
      codex) ;;
      *) die "unknown host: ${HOST} (expected codex)" ;;
    esac
    TARGET_HOSTS=("$HOST")
    return
  fi

  TARGET_HOSTS=(codex)
}

skills_dir_for_host() {
  case "$1" in
    codex) printf '%s\n' "${HOME}/.codex/skills" ;;
    *) die "unsupported host: $1" ;;
  esac
}

host_label() {
  case "$1" in
    codex) printf '%s\n' "Codex" ;;
    *) die "unsupported host: $1" ;;
  esac
}

ensure_symlink_or_absent() {
  local path="$1"

  if [ -e "$path" ] && [ ! -L "$path" ]; then
    die "${path} already exists and is not a symlink"
  fi
}

cleanup_legacy_codev_skill() {
  local skill_name="$1"
  local path="${SKILLS_DIR}/${skill_name}"
  local actual

  if [ ! -L "$path" ]; then
    return
  fi

  actual="$(readlink "$path")"

  if [ "$actual" = "codev/skills/${skill_name}" ] || [ "$actual" = "${REPO_ROOT}/skills/${skill_name}" ]; then
    rm -f "$path"
  fi
}

install_for_host() {
  local host="$1"
  local skill_name

  SKILLS_DIR="$(skills_dir_for_host "$host")"

  mkdir -p "$SKILLS_DIR"

  ensure_symlink_or_absent "${SKILLS_DIR}/${PROJECT_NAME}"

  for skill_name in "${MANAGED_SKILLS[@]}"; do
    ensure_symlink_or_absent "${SKILLS_DIR}/${skill_name}"
  done

  ln -snf "$REPO_ROOT" "${SKILLS_DIR}/${PROJECT_NAME}"

  for skill_name in "${MANAGED_SKILLS[@]}"; do
    ln -snf "${PROJECT_NAME}/skills/${skill_name}" "${SKILLS_DIR}/${skill_name}"
  done

  for skill_name in "${LEGACY_CODEV_SKILLS[@]}"; do
    cleanup_legacy_codev_skill "$skill_name"
  done

  for skill_name in "${REMOVED_MANAGED_SKILLS[@]}"; do
    cleanup_legacy_codev_skill "$skill_name"
  done

  echo "codev ready for $(host_label "$host")."
  echo "  repo: ${REPO_ROOT}"
  echo "  skills: ${SKILLS_DIR}"
  echo "  linked: ${MANAGED_SKILLS[*]}"
}

parse_args "$@"

for host in "${TARGET_HOSTS[@]}"; do
  install_for_host "$host"
done

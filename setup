#!/usr/bin/env bash
set -euo pipefail

PROJECT_NAME="codev"
REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)"
SKILLS_DIR="${HOME}/.codex/skills"
GSTACK_DIR="${HOME}/gstack"
GSTACK_REPO_URL="https://github.com/garrytan/gstack.git"
MANAGED_SKILLS=(codev-memorize codev-issue2task codev-gstack2task codev-taskdev codev-autodev codev-quickship codev-automerge codev-checktask codev-simplify codev-checkpoint)
LEGACY_CODEV_SKILLS=(plantask memorize issue2task gstack2task taskdev autodev automerge checktask simplify checkpoint ships)

die() {
  echo "codev setup failed: $*" >&2
  exit 1
}

ensure_command() {
  local command_name="$1"
  command -v "$command_name" >/dev/null 2>&1 || die "${command_name} is required but not installed"
}

ensure_symlink_or_absent() {
  local path="$1"

  if [ -e "$path" ] && [ ! -L "$path" ]; then
    die "${path} already exists and is not a symlink"
  fi
}

cleanup_legacy_codev_skill() {
  local skill_name="$1"
  local path="${SKILLS_DIR}/${skill_name}"
  local actual

  if [ ! -L "$path" ]; then
    return
  fi

  actual="$(readlink "$path")"

  if [ "$actual" = "codev/skills/${skill_name}" ] || [ "$actual" = "${REPO_ROOT}/skills/${skill_name}" ]; then
    rm -f "$path"
  fi
}

bootstrap_gstack() {
  ensure_command git

  if [ -e "$GSTACK_DIR" ] && [ ! -d "$GSTACK_DIR" ]; then
    die "${GSTACK_DIR} exists and is not a directory"
  fi

  if [ ! -e "$GSTACK_DIR" ]; then
    echo "Bootstrapping gstack..."
    git clone "$GSTACK_REPO_URL" "$GSTACK_DIR" >/dev/null || die "failed to clone gstack into ${GSTACK_DIR}"
  elif [ ! -d "${GSTACK_DIR}/.git" ]; then
    die "${GSTACK_DIR} exists but is not a git repository"
  else
    echo "Updating gstack..."
    git -C "$GSTACK_DIR" pull --ff-only >/dev/null || die "failed to update gstack in ${GSTACK_DIR}"
  fi

  [ -x "${GSTACK_DIR}/setup" ] || die "gstack setup script is missing at ${GSTACK_DIR}/setup"

  echo "Installing gstack for Codex..."
  "${GSTACK_DIR}/setup" --host codex >/dev/null || die "gstack setup failed"
}

bootstrap_gstack

mkdir -p "$SKILLS_DIR"

ensure_symlink_or_absent "${SKILLS_DIR}/${PROJECT_NAME}"

for skill_name in "${MANAGED_SKILLS[@]}"; do
  ensure_symlink_or_absent "${SKILLS_DIR}/${skill_name}"
done

ln -snf "$REPO_ROOT" "${SKILLS_DIR}/${PROJECT_NAME}"

for skill_name in "${MANAGED_SKILLS[@]}"; do
  ln -snf "${PROJECT_NAME}/skills/${skill_name}" "${SKILLS_DIR}/${skill_name}"
done

for skill_name in "${LEGACY_CODEV_SKILLS[@]}"; do
  cleanup_legacy_codev_skill "$skill_name"
done

echo "codev ready."
echo "  repo: ${REPO_ROOT}"
echo "  skills: ${SKILLS_DIR}"
echo "  linked: ${MANAGED_SKILLS[*]}"
